# Jira Configuration
JIRA_BASE_URL=https://yourbank.atlassian.net
JIRA_API_TOKEN=your_api_token_here
JIRA_EMAIL=your.email@bank.com
JIRA_PROJECT_KEY=QA

# WhatsApp Configuration (optional - for trigger interface)
WHATSAPP_WEBHOOK_URL=https://your-webhook-url
WHATSAPP_AUTH_TOKEN=your_auth_token_here

# Shared Volume Configuration
# Path to Role 1's shared volume
SHARED_VOLUME_PATH=/Users/kianwoonwong/Downloads/qa-swarm-project/shared
SHARED_SCRIPTS_DIR=${SHARED_VOLUME_PATH}/egress
SHARED_RESULTS_DIR=${SHARED_VOLUME_PATH}/results

# Executor Service
EXECUTOR_HOST=0.0.0.0
EXECUTOR_PORT=8001
EXECUTOR_LOG_LEVEL=INFO

# Monitor Service
MONITOR_HOST=0.0.0.0
MONITOR_PORT=8002
MONITOR_LOG_LEVEL=INFO
MONITOR_SAMPLE_INTERVAL_MS=100

# Jira Integrator Service
JIRA_INTEGRATOR_HOST=0.0.0.0
JIRA_INTEGRATOR_PORT=8003
JIRA_INTEGRATOR_LOG_LEVEL=INFO

# Health Thresholds
HEALTH_MEMORY_LEAK_THRESHOLD_MB=100
HEALTH_MEMORY_LEAK_WINDOW_SECONDS=60
HEALTH_CPU_WARNING_PERCENT=60
HEALTH_CPU_CRITICAL_PERCENT=80
HEALTH_CPU_IDLE_WINDOW_SECONDS=5

# Execution Settings
EXECUTION_TIMEOUT_SECONDS=300
BROWSER_HEADLESS=true
BROWSER_SLOW_MO_MS=0

# Docker Configuration
DOCKER_NETWORK=nanoclaw_network
EXECUTOR_CONTAINER_NAME=nanoclaw_executor
MONITOR_CONTAINER_NAME=nanoclaw_monitor
JIRA_CONTAINER_NAME=nanoclaw_jira

# Playwright Configuration
PLAYWRIGHT_TRACE_ON=true
PLAYWRIGHT_TRACE_RETAIN_ON_FAILURE=true
PLAYWRIGHT_SCREENSHOT_ON_FAILURE_ONLY=true
